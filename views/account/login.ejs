
<h1><%= title %></h1>

<% if (message) { %>
  <div class="flash-message">
    <p><%= message %></p>
  </div>
<% } %>

<form action="/account/login" method="POST" class="login-form">
  <label for="email">Email:</label>
  <input type="email" id="email" name="account_email" required>

  <label for="password">Password:</label>
  <input type="password" id="password" name="account_password" required>

  <button type="submit">Login</button>
</form>

<p>No account? <a href="/account/register">Sign-Up</a></p>
